			"contents": "<?php\n\t/**\n\t* \n\t*/\n\tclass ConferencesController extends AppController\n\t{\n\t\tpublic $uses = array('Conference', 'Journal', 'Tariff', 'Variable', 'User', 'Wallet');\n\t\tpublic $components = array('Auth');\n\t\tpublic $helpers = array('Tariff');\n\n\t\t/**\n\t\t * Просмотр списка конференции или информации о конкретной конференции.\n\t\t * Не реализовано, т.к. неизвестно нужен ли данный функционал.\n\t\t * \n\t\t * @param  int $id Идентификатор конференции, если он не задан, то выводится список,\n\t\t * иначе выводится информация о конкретной конференции\n\t\t * @return void\n\t\t */\n\t\tpublic function index($id = null) {\n\t\t\t//$this->Conference->find('all');\n\t\t\t$this->set('conferences', $this->Conference->find('all'));\n        \t$this->set('title_for_layout', Configure::read('Site.title'));\n\t\t}\n\n\t\t/**\n\t\t * Регистрирует новую конференцию/журнал.\n\t\t * @return void\n\t\t */\n\t\tpublic function register() {\n\t\t\tif (!empty($this->request->data)) {\n\n\t\t\t\t$tariff = $this->Tariff->findById($this->request->data['Conference']['tariff']);\n\t\t\t\tif ($tariff['Tariff']['name'] == 'Журнал') {\n\t\t\t\t\t$conference = $this->Journal;\n\t\t\t\t\t$this->request->data['Journal'] = $this->request->data['Conference'];\n\t\t\t\t} else {\n\t\t\t\t\t$conference = $this->Conference;\n\t\t\t\t}\n\n\t\t\t\t$conference->set($this->request->data);\n\t\t\t\tif ($conference->validates()) {\n\t\t\t\t\t$id = $conference->init($this->request->data);\n\t\t\t\t\t$this->Session->setFlash('Конференция создана.');\n\t\t\t\t\t$this->redirect(array(\"controller\" => \"wallet\", \"action\" => \"pay\", $id));\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t$currentUser = $this->Auth->user();\n\t\t\t$domain = $this->Variable->read('Domain');\n\t\t\t\n\t\t\t$this->set('tariffs', $this->Tariff->find('all'));\n\t\t\t$this->set('owner'  , $currentUser['id']);\n\t\t\t$this->set('domain' , $domain);\n\t\t}\n\n\t\t/**\n\t\t * Изменяет тариф конференции с указанным идентификатором.\n\t\t * @param  int $conferenceId Идентификатор конференции.\n\t\t * @return void\n\t\t */\n\t\tpublic function tariff($conferenceId) {\n\t\t\t$conference = $this->getUserConferenceOrRedirect($conferenceId);\n\n\t\t\tif (!empty($this->request->data)) {\n\t\t\t\tif ($this->request->data['Conference']['currentTariff'] != $this->request->data['Conference']['tariff']) {\n\t\t\t\t\tif ($this->Conference->save($this->request->data)) {\n\t\t\t\t\t\t$this->Session->setFlash('Тариф изменен.');\n\t\t\t\t\t\t$this->redirect(array('controller' => \"users\", \"action\" => \"myconferences\", \"id\" => $conferenceId));\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\t$this->redirect(array('controller' => \"users\", \"action\" => \"myconferences\", \"id\" => $conferenceId));\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t$this->set('conference', $conference);\n\t\t\t$this->set('tariffs', $this->Tariff->find('all'));\n\t\t\t$this->set('currentTariff', $conference['Tariff']['id']);\n\t\t}\n\n\t\t/**\n\t\t * Отключает работу конференции.\n\t\t * @param  int $conferenceId Идентификатор конференции.\n\t\t * @return void\n\t\t */\n\t\tpublic function deactivate($conferenceId) {\n\t\t\t$this->set('conference', $this->getUserConferenceOrRedirect($conferenceId));\n\n\t\t\tif (!$this->Conference->isAbleToShutdown($conferenceId)) {\n\t\t\t\t$this->view = 'unableToShutdown';\n\t\t\t\treturn;\n\t\t\t} \n\n\t\t\tif (!empty($this->request->data)) {\n\t\t\t\tif ($this->request->data['answer'] == 'agree') {\n\t\t\t\t\t$this->Conference->deactivate($conferenceId);\n\t\t\t\t\t$this->Session->setFlash('Конференция отключена.');\n\t\t\t\t} \n\n\t\t\t\t$this->redirect(array('controller' => \"users\", \"action\" => \"myconferences\", \"id\" => $conferenceId));;\n\t\t\t}\n\t\t}\n\n\t\t/**\n\t\t * Активирует конференцию с заданным идентификатором.\n\t\t * @param  int $conferenceId Идентификатор конференции.\n\t\t * @return void\n\t\t */\n\t\tpublic function activate($conferenceId) {\n\t\t\t$conference = $this->getUserConferenceOrRedirect($conferenceId);\n\t\t\t$this->set('conference', $conference);\n\n\t\t\tif ($this->Conference->deactivatedInThisMonth($conferenceId)) {\n\t\t\t\t$this->view = 'activateInSameMonth';\n\t\t\t} else {\n\t\t\t\t$activationCost = $this->Conference->calculateActivationCost($conferenceId);\n\t\t\t\t$this->set('payToActivate', $activationCost);\n\n\t\t\t\tif (!$this->User->Wallet->have($conference['Conference']['owner'], $activationCost)) {\n\t\t\t\t\t$this->Session->setFlash(\n\t\t\t\t\t\t\"Недостаточно средств для активации конференции.<br> \n\t\t\t\t\t\tДля активации необходимо $activationCost р.\");\n\t\t\t\t\t\n\t\t\t\t\t$this->redirect(array('controller' => \"users\", \"action\" => \"myconferences\", \"id\" => $conferenceId));\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif (!empty($this->request->data)) {\n\t\t\t\tif ($this->request->data['answer'] == 'agree') {\n\t\t\t\t\t$result = $this->Conference->activate($conferenceId);\n\t\t\t\t\tif ($result)\n\t\t\t\t\t\t$this->Session->setFlash(\"Конференция успешно активирована.\");\n\t\t\t\t\telse \n\t\t\t\t\t\t$this->Session->setFlash(\"Недостаточно средств для активации конференции.\");\n\t\t\t\t}\n\n\t\t\t\t$this->redirect(array('controller' => \"users\", \"action\" => \"myconferences\", \"id\" => $conferenceId));\n\t\t\t}\n\t\t}\n\n\t\t/**\n\t\t * Возвращает конференцию пользователя или переадресовывает пользователя,\n\t\t * если конференция не найдена или ему не принадлежит.\n\t\t * @param  int \t\t\t\t$conferenceId Идентификатор конференции.\n\t\t * @return Conference/void\n\t\t */\n\t\tprivate function getUserConferenceOrRedirect($conferenceId) {\n\t\t\t$currentUser = $this->Auth->user();\n\t\t\t$conference  = $this->User->getConference($currentUser['id'], $conferenceId);\n\t\n\t\t\tif (!$conference) {\n\t\t\t\t$this->Session->setFlash('Данные по заданной конференции не найдены.');\n\t\t\t\t$this->redirect('/');\n\t\t\t}\n\t\t\treturn $conference;\n\t\t}\n\n\t\tpublic function beforeFilter() {\n\t\t\tparent::beforeFilter();\n\t\t\t$this->Auth->deny('*');\n\t\t\t$this->Auth->allow('index');\n\t\t}\n\t}\n?>",
