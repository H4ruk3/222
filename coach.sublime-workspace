nDict;\n\t\tvar semestr = this.editor.getValue(\"timetableBeginDat\");\n\t\tif (semestr == null) {\n\t\t\teditor.setValue(\"timetable\", \"\");\n\t\t\teditor.setFieldState(\"timetable\", \"disabled\");\n\t\t} else\n\t\tif (timetables != null) {\n\t\t\tvar textVal = \"Количество строк: \" + timetables.length;\n\t\t\teditor.setValue(\"timetable\", textVal);\n\t\t}\n\t\tvar prepodListDict = new $wnd.marc.DictionaryJS(\"prepodslist\");\n\t\tvar prepods = prepodListDict.select({'parent_id' : $wnd.marc.UtilsJS.getId(mBean)});\n\t\tif (prepods != null) {\n\t\t\tvar textVal = \"Количество преподавателей: \" + prepods.length;\n\t\t\teditor.setValue(\"prepodList\", textVal);\n\t\t}\n\t},\n\n\tonGroupCellRenderer: function(bean, property) {\n\t\t//alert(\"рендер группы\");\n\t\tvar cellbean = new $wnd.marc.BeanJS(bean).getValue(property);\n\t\tif (cellbean != null && typeof cellbean != 'string') {\n\t\t\t//alert(cellbean)\n\t\t\tvar beanjs = new $wnd.marc.BeanJS(\"timetable bean\", this.groupdict.fields(), cellbean);\n\t\t\treturn beanjs.getValue(\"title\");\n\t\t}\n\t\telse {\n\t\t\treturn \"\";\n\t\t}\n\t},\n\n\tonCourceCellRenderer: function(cnt, data) {\n\t\treturn \"Расписание \" + (Math.ceil(parseInt(data)/2)) + \" курса (\" + cnt + (cnt == 1?\"группа\":\"групп\") + \")\";\n\t\t//alert(data.models);\n\t\t//alert(\"рендер группы\");\n\t\t/*var cellbean = new $wnd.marc.BeanJS(bean).getValue(property);\n\t\tif (cellbean != null && typeof cellbean == 'string') {\n\t\t\tvar st = \"Расписание для \" + cellbean + \" курса\";\n\t\t\talert(st)\n\t\t\treturn \"Расписание для \" + cellbean + \" курса\";\n\t\t}\n\t\telse {\n\t\t\talert(cellbean);\n\t\t\treturn cellbean;\n\t\t}*/\n\t},\n\n\tonCellRender: function(bean, property) {\n\t\t//alert(\"Редактирование строки\");\n\t\tvar cellbean = new $wnd.marc.BeanJS(bean).getValue(property);\n\t\tif (cellbean != null && typeof cellbean != 'string') {\n\t\t\t//alert(cellbean)\n\t\t\tvar beanjs = new $wnd.marc.BeanJS(\"timetable bean\", thi