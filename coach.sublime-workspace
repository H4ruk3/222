plinDict.fields(), learningPlan.getValue(\"idDisciplin\"));\n\t\t//var v = this.learningplan_tabe.checkIfFieldValueExists(\"f1\", disciplinBean.getValue('title'));\n\t\t//alert(v);\n\t\t//return v==true?1:0;\n\t},\n\n\tbtnTimetable: function()\n\t{\n\t\t//alert(\"Кнопка\");\n\t\tconsole.log(\"skdOrgType_Librarian: btnLearningPlan button pressed\");\n\n\t\t\n\t\tvar timetablewnd = new $wnd.marc.CWTableDialog(\"timetable\");\n\t\ttimetablewnd.setCellSelectionMode(true);\n\t\ttimetablewnd.setHeading(\"Расписание\");\n\t\ttimetablewnd.setWidth(1100);\n\t \ttimetablewnd.setHeight(600);\n\t \tvar onGroupCellRenderer = this.onGroupCellRenderer.bind(this);\n\t \tvar onCourceCellRenderer = this.onCourceCellRenderer.bind(this);\n\t \ttimetablewnd.addColumn(\"group\", \"Группа\", 400, onGroupCellRenderer);\n\t \ttimetablewnd.addColumn(\"cource\", \"Курс\", 100);\n\t \ttimetablewnd.groupBy(\"cource\", onCourceCellRenderer);\n\t \ttimetablewnd.changeButtonState(false,false,false);\n\t \t//Рассчитываем периоды обучения\n\t \tvar onCellRender = this.onCellRender.bind(this);\n\t \tvar dates = this.utils.readSystemSetting($wnd.marc.SystemSetting.CIKL_START_DAY);\n\t\tvar cntdays = this.utils.readSystemSetting($wnd.marc.SystemSetting.CNT_DAYS);\n\t\tvar cntWeeks = this.utils.readSystemSetting($wnd.marc.SystemSetting.CNT_WEEKS);\n\t\t//alert(this.utils.formatDate(dates,\"MM/dd/yyyy\"));\n\t\tdate = new Date(this.utils.formatDate(dates,\"MM/dd/yyyy\"));\n\t\tvar date_end = new Date(date);\n\t\tdate_end.setTime( date.getTime() + (cntdays-date.getDay()) * 86400000 );\n\t\t//date_end.setDate(date.getDate() + cntdays-date.getDay());\n\t\t////alert(date_end);\n\t\tfor (i=0; i<cntWeeks; i++) {\t\t\n\t\t\tvar str = date.getDate()+\".\"+(1 + date.getMonth())+\" - \"+date_end.getDate()+\".\"+(1 + date_end.getMonth());\n\t\t\ttimetablewnd.addColumn(\"d\"+i, str, 100, onCellRender);\n\t\t\t//date.setDate(date_end.getDate() + 8-cntdays);\n\t\t\tdate.setTime( date_end.getTime() + (8 - cntdays) * 86400000 );\n\t\t\tdate_end.setTime( date.getTime() + (cntdays - 1) * 86400000 );\n\t\t\t//date_end.setDate(date.getDate() + cntdays);\n\t\t\t//alert(\"date \" + date);\n\t\t\t//alert(\"date_end \" + date_end);\n\t\t}\n\n\n\t \t\n\t \t/*timetablewnd.addColumn(\"d1\", \"10.04 - 12.04\", 100, onCellRender);\n\t \ttimetablewnd.addColumn(\"d2\", \"10.04 - 12.04\", 100, onCellRender);\n\t \ttimetablewnd.addColumn(\"d3\", \"10.04 - 12.04\", 100, onCellRender);\n\t \ttimetablewnd.addColumn(\"d4\", \"10.04 - 12.04\", 100, onCellRender);\n\t \ttimetablewnd.addHeaderGroup(\"Учебная неделя\", 0, 1, 1, 4);\n\t \t*/\n\t \t//Add data\n\t \tvar descId = new $wnd.marc.BeanJS(this.editor.getRecord()).getValue(\"descId\");\n\t \tvar ds = new $wnd.marc.DescStructJS();\n\t\t////alert(\"ok\");\n\t\tds.setId(Number(descId));\n\t\t//var ds = new $wnd.marc.DescStructJS(1);\n\t\t////alert(\"tut\");\n\t\t//Вычисляем текущий семестр и бирём расписание только для него\n\n\n\t\tvar groups = ds.getGroups();\n\t\tfor (var i=0; i<groups.length; i++){\n\t\t\tvar group = new $wnd.marc.TreeItemJS(groups[i]);\n\t\t\tvar dict = new $wnd.marc.DictionaryJS(group.getDictId());\n\t\t\t//alert(dict);\n\t\t\tthis.groupdict = dict;\n\t\t\tvar dbean = dict.selectSingle({'id' : Number(group.getTitle())});\n\t\t\t//alert(dbean);\n\t\t\t\n\t\t\tvar beanjs = new $wnd.marc.BeanJS(\"group_bean\", dict.fields(), dbean);\n\t\t\talert(\"tut\");\n\t\t\tif (parseInt(new $wnd.marc.BeanJS(beanjs.getValue(\"semestr\")).getValue(\"value\")) >= parseInt(new $wnd.marc.EnumJS(this.editor.getValue(\"timetableBeginDat\")).getValue())){\n\t\t\t\t//alert(beanjs.getValue(\"semestr\"));\n\t\t\t\t//new $wnd.marc.BeanJS(beanjs.getValue(\"semestr\"));\n\t\t\t\talert(\"tut2\");\n\t\t\t\tvar bean = new $wnd.marc.BeanJS(\"table data\", null);\n\t\t \t\tbean.setValue(\"group\", dbean);\n\t\t \t\tbean.setValue(\"cource\", String(Math.ceil(parseInt(new $wnd.marc.BeanJS(beanjs.getValue(\"semestr\")).getValue(\"value\")))));\n\t\t \t\t//bean.setValue(\"d1\", \"\");\n\t\t \t\t//bean.setValue(\"d2\", \"\");\n\t\t\t\t//bean.setValue(\"d3\", \"\");\n\t\t\t\t//bean.setValue(\"d4\", \"\");\n\t\t\t\tvar timetables = this.timetableDict.select({'parent_id' : $wnd.marc.UtilsJS.getId(mBean), 'group' : dbean});\n\t\t\t\t//alert(timetables);\n\t\t\t\tif (timetables != null) {\n\t\t\t\t\tfor (j = 0; j < timetables.length; j++) {\n\t\t\t\t\t\tvar ttbeanjs = new $wnd.marc.BeanJS(\"timetable\", this.timetableDict.fields(), timetables[j]);\n\t\t\t\t\t\tttbeanjs.setValue(\"commited\", true);\n\t\t\t\t\t\t//alert(ttbeanjs.getValue(\"numNedeli\"));\n\t\t\t\t\t\tbean.setValue(\"d\" + (parseInt(ttbeanjs.getValue(\"numNedeli\"))-1), ttbeanjs.getModel());\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\ttimetablewnd.addRecord(bean.getBean());\n\t\t\t}\n\t\t} \n\t\t\n\t\t////alert(group.getDictId());\n\t\t////alert(group.getTitle());\n\t\t//var dic = new $wnd.marc.DictionaryJS(group.getDictId());\n\n\n\t \t\n\t \ttimetablewnd.show();\n\t\tthis.timetablewnd = timetablewnd;\n\t\ttimetablewnd.setOnAdd(this.onAddRecord.bind(this));\n\t\ttimetablewnd.setOnEdit(this.onEditRecord.bind(this));\n\t\ttimetablewnd.setOnRemove(this.onRemoveRecord.bind(this));\n\t\ttimetablewnd.setBeforeSaveRecord(this.onBeforeSaveRecord.bind(this));\n\t\ttimetablewnd.setOnSave(this.onSaveRecord.bind(this));\n\t\ttimetablewnd.setOnEditEnd(this.onEditRecordEnd.bind(this));\n\t\ttimetablewnd.setOnClose(this.onClose.bind(this));\n\t\ttimetablewnd.setOnProcessRecord(this.onProcessRecord.bind(this));\n\t\t//return this.timetablewnd.cntRecord();\n\t \t//timetablewnd.addColumn(\"cikl\", \"Цикл\", 200);\n\t \t//timetablewnd.groupBy(\"cikl\");\n\n\t \t\n\t},\n\n\tonAddRecord: function() {\n\t\t//alert(\"Добавление записи\");\n\t\tvar beanjs = new $wnd.marc.BeanJS(\"group_bean\", this.timetableDict.fields());\n\t\tvar rec = new $wnd.marc.BeanJS(this.timetablewnd.getRecord());\n\t\t//alert(parseInt(rec.getValue(\"cource\")));\n\t\t//alert(rec.getValue(\"group\"));\n\t\tbeanjs.setValue(\