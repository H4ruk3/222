.updateRecord(rec.getBean());\n\t},\n\n\tonSaveRecord: function(bean) {\n\t\n\t\tvar ttbeanjs = new $wnd.marc.BeanJS(\"timetable\", this.timetableDict.fields(), bean);\n\t\t//alert(bean);\n\t\tvar rec = new $wnd.marc.BeanJS(this.timetablewnd.getRecord());\n\t\t//alert(rec);\n\t\t////alert(ttbeanjs.getValue(\"numNedeli\"));\n\t\t//bean.setValue(\"d\" + (parseInt(ttbeanjs.getValue(\"numNedeli\")) + 1), timetables[i]);\n\t\trec.setValue(\"d\" + (this.timetablewnd.getSelectedCell()), bean);\n \t\tthis.timetablewnd.updateRecord(rec.getBean());\n\t},\n\n\tonClose: function() {\n\t\t//mBean = this.editor.getRecord()\n\t\t//var timetables = this.timetableDict.select({'parent_id' : $wnd.marc.UtilsJS.getId(mBean)});\n\t\t//if (timetables != null) {\n\t\t\tvar textVal = \"Количество строк: \" + this.timetablewnd.cntItems();\n\t\t\t//alert(textVal);\n\t\t\tthis.editor.setValue(\"timetable\", textVal);\n\t\t//}\n\t},\n\n\tonProcessRecord: function(record){\n\t\tcnt = 0;\n\t\tvar rec = new $wnd.marc.BeanJS(record);\n\t\tvar cntWeeks = this.utils.readSystemSetting($wnd.marc.SystemSetting.CNT_WEEKS);\n\t\tfor(i=0; i<cntWeeks; i++){\n\t\t\tif (rec.getValue(\"d\" + i) != null)\n\t\t\t\tcnt += 1;\n\t\t}\n\t\treturn cnt;\n\t},\n\n\tonRecordEditFinish: function(applied)\n\t{\n\t\tconsole.log(\"skdOrgType_Librarian: finish record edit\");\n\t\tif (this.timetablewnd != undefined)\n\t\tif (applied)\n\t\t\tthis.timetablewnd.confirmHistory();\n\t\telse\n\t\t\tthis.timetablewnd.clearHistory();\n\t\t//alert(\"save tut\");\n\t\t//this.editor.setValue(\"learningPlan\", this.learningplan_tabe.cntRecord());\n\t},\n\n\t//Кнопка редактирования списка преподавателей.\n\tbtnPrepodList: function(){\n\t\t//var prepodlistwnd = new $wnd.marc.CWTableDialog(\"timetable\");\n\t\tvar dictionary = \"prepodslist\";\n\t\tvar parentId = new $wnd.marc.BeanJS(this.editor.getRecord()).getId();\n\t\tvar title = \"test\";\n\t\t//var wnd1 = new $wnd.marc.CWDictionaryDialog(); \n\t\tvar wnd = new $wnd.marc.CWDictionaryD