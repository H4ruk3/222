lds(dao, CTTableFields.class, tblFund.getId(), new String[]\n{\n\t\"skCatalogueRecord\", \"skInventoryNumber\", \"skBarCode\", \"skCardNumber\", \"skBookWarehouse\",\n\t\"skKSURecord\", \"skFundNumber\", \"skFormat\", \"skPrice\", \"skCount\", \"skState\", \"skRackIndex\",\n\t\"skAddSource\", \"skAddDocumentNumber\", \"skAddDocumentDate\", \"skAddDate\",\n\t\"skRemoveReason\", \"skRemoveActNumber\", \"skRemoveActDate\", \"skRemoveDate\"\n});\n\nFile file = File.createTempFile(job.getSource().getName()+\"_\", \".srr\", SystemHelper.getFileTemporaryDir());\nFileOutputStream fos = new FileOutputStream(file);\nwriter = new BufferedWriter(new OutputStreamWriter(fos, \"UTF-8\"));\n\njob.addCleanup(writer);\njob.addCleanup(fos);\n\nTableDAO tableDAO = new TableDAO(dao);\n\nDictionaryDAO dictionaryDAO = new DictionaryDAO(dao);\n\nCTDictionary ksuDictionary = ModelHelper.loadModel(dao, CTDictionary.class, \"skdKSU1\");\nMap ksuFields = ModelHelper.loadFields(dao, CTDictionaryFields.class, ksuDictionary.getId(), new String[]\n{\n\t\"skNumber\", \"skDocumentDate\"\n});\n\nlist = dictionaryDAO.find(ksuDictionary.getId(), ModelHelper.getFieldDBName(\"skNumber\", ksuFields)+\" = '\"+job.getParameter(\"skKSU\")+\"'\");\nCMBeanModel ksu = list.get(0);\n\nwriter.write(\"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\");\nwriter.write(\"<report>\");\nwriter.write(\"<sigla>\"+sigla+\"</sigla>\");\nwriter.write(\"<ksu>\"+job.getParameter(\"skKSU\")+\"</ksu>\\n\");\nwriter.write(\"<date>\"+ksu.get(ModelHelper.getFieldDBName(\"skDocumentDate\", ksuFields))+\"</date>\\n\");\n\nString clause = ModelHelper.getFieldDBName(\"skKSURecord\", fmFund)+\"=\"+ksu.getId();\n\nlong size = 0;\nStatement stmt = dao.getStatement(); job.addCleanup(stmt);\nResultSet rs = stmt.executeQuery(\"select count(*) from \"+DAOFactory.DBPREFIX+\"table\"+tblFund.getId()+\" where coalesce(deleted, false)=false and \"+clause);\nif(rs.next()) size = rs.getLong(1); rs.close();\n\nlong count = 0; long update = 0; Map